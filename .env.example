# Public site
# Keep false until the storefront is ready for launch.
NEXT_PUBLIC_SITE_LIVE=false
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="+351910341182"

# Database
# SQLite paths are resolved relative to prisma/schema.prisma.
# Leave DATABASE_URL unset on Vercel to use the bundled prisma/dev.db preview database,
# or replace this with a managed production database URL.
DATABASE_URL="file:./dev.db"

# Authentication
AUTH_SECRET="replace-with-a-long-random-value"
AUTH_URL="http://localhost:3000"

# Cloudinary (optional during construction mode)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
